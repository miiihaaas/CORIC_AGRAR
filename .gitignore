# =============================================================================
# CORIC_AGRAR — .gitignore
# Tech stack: Python 3.13 + Django 5.2 + uv + PostgreSQL + Docker + Playwright
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
build/
dist/
develop-eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# uv (Python package manager) — NOTE: uv.lock IS committed (reproducible builds)
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# -----------------------------------------------------------------------------
# Environment variables & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# Local SQLite fallback (dev only — prod uses PostgreSQL)
*.sqlite3
*.sqlite3-journal
db.sqlite3

# Local settings (use settings split + .env instead, but safety net)
local_settings.py

# Collected static files (generated by `collectstatic` at build/deploy)
staticfiles/
/static_collected/

# User-uploaded media (sorl-thumbnail cache + product images + PDF brošure)
media/
!media/.gitkeep

# Django i18n compiled message catalogs (compile from .po at deploy)
*.mo

# Django session/cache backends if file-based
django_cache/

# -----------------------------------------------------------------------------
# Logs (Django logging → /var/log/django/app.log in prod; local logs/)
# -----------------------------------------------------------------------------
*.log
logs/
log/

# -----------------------------------------------------------------------------
# Testing (pytest-django + Playwright)
# -----------------------------------------------------------------------------
.pytest_cache/
.cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
nosetests.xml
test-results/
junit.xml

# Playwright E2E artifacts
/playwright-report/
/playwright/.cache/
/test-results/
/blob-report/
playwright/.auth/

# -----------------------------------------------------------------------------
# Linters & formatters (ruff, mypy, djade — cache only)
# -----------------------------------------------------------------------------
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# -----------------------------------------------------------------------------
# Pre-commit
# -----------------------------------------------------------------------------
# (keep .pre-commit-config.yaml in repo — only cache is ignored)
.pre-commit-cache/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Compose override is for personal local tweaks
docker-compose.override.yml
compose/*.override.yml
# Container runtime data (postgres data volume mounted to host in dev)
.docker-data/
postgres-data/
pgdata/

# -----------------------------------------------------------------------------
# Backup / dump artifacts (pg_dump, restic, media backups — Story 9.5)
# -----------------------------------------------------------------------------
*.sql
*.sql.gz
*.dump
*.bak
backups/
restic-cache/

# -----------------------------------------------------------------------------
# Node / frontend tooling (if used for asset building later)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.parcel-cache/
.vite/

# -----------------------------------------------------------------------------
# IDE & editor
# -----------------------------------------------------------------------------
# VS Code — keep shared settings, ignore personal
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace

# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.iws

# Sublime
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
.\#*
\#*\#

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Sentry / GlitchTip (Story 9.3) — local debug symbols / artifacts
# -----------------------------------------------------------------------------
.sentryclirc

# -----------------------------------------------------------------------------
# BMad working & tmp artifacts (keep finalized planning/implementation in repo)
# -----------------------------------------------------------------------------
_bmad-output/**/.working/
_bmad-output/**/tmp/
_bmad-output/**/*.tmp.md
_bmad/scripts/__pycache__/

# -----------------------------------------------------------------------------
# BMad installer-managed (re-installable via BMad CLI — not source of truth)
# Trackovano: _bmad/config.toml, _bmad/custom/, _bmad/scripts/, _bmad-output/
# -----------------------------------------------------------------------------
.claude/skills/
.claude/settings.local.json
.claude/.credentials.json
_bmad/_config/
_bmad/automator/
_bmad/bmb/
_bmad/bmm/
_bmad/core/
_bmad/tea/
_bmad/wds/
_bmad/config.user.toml

# Portable orchestrator bundle (duplikat sadržaja iz .claude/ i _bmad/)
bmad-orchestrators-bundle/

# -----------------------------------------------------------------------------
# Design source assets — large binary files (PSD, HTML mockups, vendor PDFs)
# 1.3 GB total — koristi Dropbox/Drive za source assets, ne git
# Trackovano: docs/*.md (Projektni zadatak)
# -----------------------------------------------------------------------------
docs/Dizajn/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pid
*.seed
*.tgz
*.tar.gz
.tmp/
tmp/
