# ============================================================
# Ćorić Agrar — Environment variables template
# Kopiraj ovaj fajl u `.env` (`cp .env.example .env`) i popuni vrednosti.
# `.env` se NE komituje u repo (vidi .gitignore).
# ============================================================

# ── Core Django ──────────────────────────────────────────────
# NAPOMENA: DJANGO_SETTINGS_MODULE NIJE listan ovde — `.env` se čita TEK NAKON
# što je DJANGO_SETTINGS_MODULE već postavljen kroz manage.py/wsgi.py/asgi.py
# default-e ili shell env var. Postavljanje u `.env` ne bi imalo efekta.
# Za switch između environment-a koristi:
#   - shell env var: `$env:DJANGO_SETTINGS_MODULE = "config.settings.production"` (PS) ili
#     `export DJANGO_SETTINGS_MODULE=config.settings.production` (bash)
#   - ili promeni default u manage.py/wsgi.py/asgi.py
# Default u manage.py / wsgi.py / asgi.py je `config.settings.development`.

# SECRET_KEY: generiši lokalno sa:
#   uv run python -c "import secrets; print(secrets.token_urlsafe(50))"
# Generiši preko secrets.token_urlsafe(50) — vidi Gotcha #22 (Compose $ interpolacija).
# Alternativa get_random_secret_key() koristi širi alfabet uključujući `$` koji Compose interpolira.
DJANGO_SECRET_KEY=

# Debug mode (True u local dev, False u staging/prod)
DJANGO_DEBUG=True

# Logging nivo za root/console handler (Story 9.6). Production-safe default INFO
# (NE DEBUG — log-ovao bi osetljive detalje + noise). DRŽI ≤ INFO da sentry-sdk
# INFO+→breadcrumb radi (G-13). Per-logger tightening je u settings (NE ovde).
# DJANGO_LOG_LEVEL=INFO

# Komma-separated list hostova koji smeju da serve-uju Django
# Local: localhost,127.0.0.1
# Staging: staging.example.com
# Prod: coricagrar.example,www.coricagrar.example
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────
# Format: postgres://user:pass@host:port/dbname
# Local (Docker Compose — Story 1.3): postgres://coric:coric@db:5432/coric_agrar
#   - "db" je Docker Compose servis ime (rezolvuje se kroz Docker DNS unutar compose network-a)
#   - Kad pokrenes PostgreSQL van compose-a, zameni "db" sa "localhost" ili IP-em
# Staging/Prod: ide kroz secrets u Hetzner Cloud panel-u (Story 9.1+)
#
# NAPOMENA (Gotcha #20): POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB se NE
# citaju iz .env za `db` servis u compose/local.yml — inline `environment:` blok
# nadjacava `env_file:`. SOT za DB credentials je compose/local.yml `db.environment:`.
# Ako menjas user/password, moras da update-ujes OBA mesta (compose/local.yml + DATABASE_URL ovde).
DATABASE_URL=postgres://coric:coric@db:5432/coric_agrar

# ── Email ────────────────────────────────────────────────────
# Format: smtp+tls://user:pass@host:port  ili  consolemail://  (dev)
# Local dev default je consolemail (Email se printuje u terminalu).
# Production (Epic 4): smtp+tls://api:KEY@smtp.resend.com:465
EMAIL_URL=consolemail://

# ── Security (production only) ───────────────────────────────
# HSTS max-age u sekundama. Default 31536000 (1 godina). Postavi 0 da disable-uješ HSTS.
DJANGO_SECURE_HSTS_SECONDS=31536000

# ── Production stack (Epic 9, Story 9.1) ─────────────────────
# Gunicorn worker count (formula 2*CPU+1; 2vCPU=5). Hetzner CX32 4vCPU → 9 (OQ-2).
# WEB_CONCURRENCY=5
# Gunicorn request timeout (sekunde). Default 60.
# GUNICORN_TIMEOUT=60
# HTTPS 301 redirect. Default True u prod (hardening). Lokalni HTTP smoke MORA False
# (inače 301 loop, G-11). NIKAD False u realnom prod-u sa cert-om.
# DJANGO_SECURE_SSL_REDIRECT=True
# CSRF trusted origins (lista sa scheme). Bez ovoga 403 na cross-origin POST (G-9).
# Prod: https://coricagrar.rs,https://www.coricagrar.rs ; smoke: http://localhost
# DJANGO_CSRF_TRUSTED_ORIGINS=
# Postgres credentials za prod stack (compose/production.yml čita kroz ${...}; G-5).
# Prod: Hetzner secrets. NIKAD realan password u repo-u.
# POSTGRES_DB=coric_agrar
# POSTGRES_USER=coric
# POSTGRES_PASSWORD=

# ── Deploy + SSL (Epic 9, Story 9.2) ─────────────────────────
# Produkcioni domen za certbot/Let's Encrypt cert + nginx server_name (OQ-2).
# certbot izdaje cert za <DEPLOY_DOMAIN> + www.<DEPLOY_DOMAIN>. DNS A-record MORA
# pokazivati na Hetzner box PRE prvog certbot run-a (inace ACME challenge fail).
DEPLOY_DOMAIN=
# ACME email za Let's Encrypt registraciju + expiry notifikacije (nginx-init.sh).
ACME_EMAIL=
# NAPOMENA: DEPLOY_HOST / DEPLOY_USER / DEPLOY_SSH_KEY / DEPLOY_APP_DIR /
# DEPLOY_HOST_FINGERPRINT NE idu u .env — idu kroz GitHub Actions secrets (deploy.yml
# SSH). Vidi ops/secrets/README.md. NIKAD u repo.
#
# GHCR image referenca (M2): production.yml django servis `image:` je
# ghcr.io/${GHCR_IMAGE}:${IMAGE_TAG}. `docker compose pull` na boxu povlaci CI-zgradjen
# image. Default GHCR_IMAGE=miiihaaas/coric_agrar (lowercase repo), IMAGE_TAG=latest.
# Po environment-u override-uj IMAGE_TAG (staging/production) da box povuce tacan tag.
GHCR_IMAGE=miiihaaas/coric_agrar
IMAGE_TAG=latest

# ── Error tracking (Epic 9, Story 9.3) ───────────────────────
# GlitchTip 6 self-host. Django app: production.py/staging.py rade DSN-guarded
# sentry_sdk.init (prazan DSN = no-op, Django se DIŽE bez crash-a). compose/production.yml
# diže glitchtip web+worker+sopstveni-postgres+sopstveni-redis (~512m mem limit, retention 30d).
# NAPOMENA (SM-D4): SDK-tuning var-i zadržavaju SENTRY_ prefiks (npr. SENTRY_TRACES_SAMPLE_RATE);
# GlitchTip SERVIS/KONTEJNER var-i nose GLITCHTIP_ prefiks. To NIJE typo/nedoslednost.
#
# GLITCHTIP_DSN: Django SDK init DSN. Kompatibilan sa Sentry SDK protokolom.
# Format: https://<public_key>@glitchtip.example/<project_id>. Prazan u dev/local
# (development.py/base.py NIKAD ne init-uju — nema error egress u dev-u, G-8).
GLITCHTIP_DSN=
# GlitchTip kontejner SECRET_KEY — DISTINKTAN od DJANGO_SECRET_KEY (G-6: deljenje bi
# spojilo crypto domene dve aplikacije). Generiši preko:
#   uv run python -c "import secrets; print(secrets.token_urlsafe(50))"
# token_urlsafe (NE get_random_secret_key) — izbegava `$` koji Compose interpolira (G-5).
GLITCHTIP_SECRET_KEY=
# GlitchTip SOPSTVENI postgres DATABASE_URL (NE deli app DB — separate-DB mandat, G-7).
# Format: postgres://glitchtip:<password>@glitchtip-postgres:5432/glitchtip
GLITCHTIP_DATABASE_URL=
# GlitchTip postgres creds (compose glitchtip-postgres servis čita kroz ${...}; G-5).
GLITCHTIP_POSTGRES_DB=glitchtip
GLITCHTIP_POSTGRES_USER=glitchtip
GLITCHTIP_POSTGRES_PASSWORD=
# GlitchTip SOPSTVENI redis broker/cache (app nema redis u v1).
# Format: redis://glitchtip-redis:6379/0
GLITCHTIP_REDIS_URL=
# GlitchTip URL/domena (subdomena errors.<domena> ILI port — OQ-1, Mihas odluka pre go-live).
GLITCHTIP_DOMAIN=
# Retention: event-i stariji od N dana se brišu (disk guard na ~512MB box-u, AC7/G-11).
GLITCHTIP_MAX_EVENT_LIFE_DAYS=30
# GlitchTip alert email kanal → Resend (reuse Epic 4 creds). Format: smtp+tls://user:pass@host:port
# DISTINKTAN ključ od Django EMAIL_URL (G-16: Django app već ima EMAIL_URL=consolemail://;
# dva ista ključa = operator konfuzija). compose mapira EMAIL_URL: ${GLITCHTIP_EMAIL_URL:-}
# u GlitchTip interni EMAIL_URL. Konkretno alert pravilo (koji error → kome) = GlitchTip UI
# podešavanje POSLE deploy-a (OQ-3).
GLITCHTIP_EMAIL_URL=
# Opciono override: Sentry SDK traces_sample_rate (performance APM). Default 0.0 (samo
# error tracking u v1 — ~512MB box ne podnosi trace volume). SDK-tuning var (SENTRY_ prefiks).
# SENTRY_TRACES_SAMPLE_RATE=0.0

# ── Email destinations (Epic 4) ──────────────────────────────
# Lead-gen forme šalju ovde. send_lead_email bira recipient po lead.form_type (Story 4.1).
# NON-FINAL placeholder — real recipient = OQ-4 (biznis input). Prazan → service tretira
# kao failed send (lead ostaje sačuvan).
CONTACT_EMAIL_TO=
SERVICE_EMAIL_TO=
PARTS_EMAIL_TO=

# ── Email sender + provider (Epic 4, Story 4.1) ──────────────
# Sender adresa za sve lead-gen email-ove (from). Staging/prod šalje kroz anymail Resend.
DEFAULT_FROM_EMAIL=no-reply@coricagrar.rs
# Resend API ključ (anymail backend u staging/prod). NON-FINAL placeholder — OQ-4.
ANYMAIL_RESEND_API_KEY=

# ── Tracking (Epic 7, Story 7.3) ─────────────────────────────
# GA4 Measurement ID (npr. G-XXXXXXXXXX) + Facebook Pixel ID.
# Prazno u dev/local = NIJEDAN tracker se NE učitava (čak ni uz consent — ID-prazan
# grana; no-tracker fail-safe). Realni ID-jevi idu kroz staging/prod env (Hetzner
# secrets). NE komituj realne vrednosti.
GA_MEASUREMENT_ID=
FB_PIXEL_ID=
